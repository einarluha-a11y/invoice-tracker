rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Admin allowlist lives in Firestore — no redeploy needed to add users.
    // Seed document: config/admin_emails = { emails: ['buhus2203@gmail.com', 'einar.luha@gmail.com', 'info@accountingresources.eu'] }
    // Fallback: hardcoded bootstrap list — used only if config doc is missing/unreadable.
    function isBootstrapAdmin() {
      return request.auth != null && (
        request.auth.token.email.lower() == 'buhus2203@gmail.com' ||
        request.auth.token.email.lower() == 'einar.luha@gmail.com' ||
        request.auth.token.email.lower() == 'info@accountingresources.eu'
      );
    }

    function isConfigAdmin() {
      return request.auth != null &&
        exists(/databases/$(database)/documents/config/admin_emails) &&
        request.auth.token.email.lower() in get(/databases/$(database)/documents/config/admin_emails).data.emails;
    }

    function isAdmin() {
      return isBootstrapAdmin() || isConfigAdmin();
    }

    function isMaster() {
      return exists(/databases/$(database)/documents/master_users/$(request.auth.uid));
    }

    function isAccountMember(accountId) {
      return exists(/databases/$(database)/documents/accounts/$(accountId)/users/$(request.auth.uid));
    }

    function isAccountAdmin(accountId) {
      return get(/databases/$(database)/documents/accounts/$(accountId)/users/$(request.auth.uid)).data.role == 'admin';
    }

    // config/admin_emails is self-readable by any admin (bootstrap or listed),
    // but only bootstrap admins can modify the allowlist (prevents lockout).
    match /config/admin_emails {
      allow read: if isAdmin();
      allow write: if isBootstrapAdmin();
    }

    // master_users: a user can read only their OWN master status (used by
    // AuthContext to decide whether to show the master UI). Reading other
    // uids leaked which accounts had master privileges — now forbidden.
    // Writes are still Admin-SDK only.
    match /master_users/{userId} {
      allow read: if request.auth != null && userId == request.auth.uid;
      allow write: if false; // только через Admin SDK
    }

    match /accounts/{accountId} {
      // Any authenticated user can read accounts (needed for login/registration flow)
      allow read: if request.auth != null;
      // Registration: validate name field exists and is reasonable length
      allow create: if request.auth != null
        && request.resource.data.name is string
        && request.resource.data.name.size() > 0
        && request.resource.data.name.size() < 256;
      allow update, delete: if request.auth != null && (isMaster() || isAccountAdmin(accountId));
    }

    match /accounts/{accountId}/users/{userId} {
      allow read: if request.auth != null && (isMaster() || isAccountMember(accountId));
      // Self-registration: user can only create their OWN doc, forced role=user, must match email
      allow create: if request.auth != null
        && userId == request.auth.uid
        && request.resource.data.role == 'user'
        && request.resource.data.email == request.auth.token.email;
      allow update, delete: if request.auth != null && (isMaster() || isAccountAdmin(accountId));
    }

    // Master password — readable only by master users, writable only via Admin SDK
    match /config/master_password {
      allow read: if request.auth != null && isMaster();
      allow write: if false;
    }

    match /accounts/{accountId}/companies/{companyId} {
      allow read: if request.auth != null && (isMaster() || isAccountMember(accountId));
      allow write: if request.auth != null && (isMaster() || isAccountAdmin(accountId));
    }

    // Legacy global collections — accessible by master and admins.
    // Regular account users cannot read these; data migration will move them
    // to accounts/{id}/companies/ etc over time.
    match /invoices/{invoiceId} {
      allow read, write: if request.auth != null && (isMaster() || isAdmin());
    }

    match /bank_transactions/{txId} {
      allow read, write: if request.auth != null && (isMaster() || isAdmin());
    }

    match /companies/{companyId} {
      allow read, write: if request.auth != null && (isMaster() || isAdmin());
    }

    match /raw_documents/{docId} {
      allow read, write: if request.auth != null && (isMaster() || isAdmin());
    }

    match /invoice_examples/{exId} {
      allow read, write: if request.auth != null && (isMaster() || isAdmin());
    }

    match /teacher_global_rules/{ruleId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && (isMaster() || isAdmin());
    }

    // ── Billing ────────────────────────────────────────────────────────
    // Each user has a single billing doc at users/{uid}/billing/state
    // holding plan, credit balance, trial status, and Lemon Squeezy IDs.
    //
    // Read: only the user themselves or a master (support/debug).
    // Write: NEVER from the client — writes go through billing_service.cjs
    //        (Admin SDK) driven by Lemon Squeezy webhooks. Clients must not
    //        be able to grant themselves credits, upgrade plans, or reset
    //        usage counters. If you need to mutate billing from the UI,
    //        call a backend endpoint that runs through the agent layer.
    match /users/{uid}/billing/{docId} {
      allow read: if request.auth != null && (request.auth.uid == uid || isMaster());
      allow write: if false;
    }

    // Idempotency ledger for webhook events (keyed by Lemon Squeezy event
    // id) + append-only audit log of credit spends. Write-only via Admin
    // SDK — read access for master/admin so support can audit disputes.
    match /billing_events/{eventId} {
      allow read: if request.auth != null && (isMaster() || isAdmin());
      allow write: if false;
    }

    match /{document=**} {
      allow read, write: if isAdmin();
    }
  }
}
