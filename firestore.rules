rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Admin allowlist lives in Firestore — no redeploy needed to add users.
    // Seed document: config/admin_emails = { emails: ['buhus2203@gmail.com', 'einar.luha@gmail.com', 'info@accountingresources.eu'] }
    // Fallback: hardcoded bootstrap list — used only if config doc is missing/unreadable.
    function isBootstrapAdmin() {
      return request.auth != null && (
        request.auth.token.email.lower() == 'buhus2203@gmail.com' ||
        request.auth.token.email.lower() == 'einar.luha@gmail.com' ||
        request.auth.token.email.lower() == 'info@accountingresources.eu'
      );
    }

    function isConfigAdmin() {
      return request.auth != null &&
        exists(/databases/$(database)/documents/config/admin_emails) &&
        request.auth.token.email.lower() in get(/databases/$(database)/documents/config/admin_emails).data.emails;
    }

    function isAdmin() {
      return isBootstrapAdmin() || isConfigAdmin();
    }

    // config/admin_emails is self-readable by any admin (bootstrap or listed),
    // but only bootstrap admins can modify the allowlist (prevents lockout).
    match /config/admin_emails {
      allow read: if isAdmin();
      allow write: if isBootstrapAdmin();
    }

    match /{document=**} {
      allow read, write: if isAdmin();
    }
  }
}
