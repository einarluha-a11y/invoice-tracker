{
  "name": "invoice-tracker",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "start": "npx pm2-runtime start ecosystem.config.cjs",
    "dev": "vite --host",
    "build": "vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "deploy": "npm run build && pm2 restart ecosystem.config.cjs && git add . && git commit -m 'chore(deploy): auto-sync full stack architecture' && git push",
    "repair": "node automation/repairman_agent.cjs",
    "postinstall": "cd automation && npm install --production"
  },
  "dependencies": {
    "firebase": "^12.9.0",
    "i18next": "^25.8.13",
    "jspdf": "^4.2.0",
    "jspdf-autotable": "^5.0.7",
    "papaparse": "^5.5.3",
    "pdfjs-dist": "^5.4.296",
    "pm2": "^6.0.14",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-i18next": "^16.5.4",
    "react-pdf": "^10.4.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/papaparse": "^5.5.2",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "firebase-admin": "^13.7.0",
    "firebase-tools": "^15.11.0",
    "globals": "^16.5.0",
    "vite": "^7.3.1",
    "vite-plugin-pwa": "^1.2.0"
  }
}
